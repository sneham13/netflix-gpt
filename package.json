{
  "name": "netflix-gpt",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "firebase": "^12.15.0",
    "openai": "^6.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "concurrently -k \"npm:watch:css\" \"npm:start:react\"",
    "start:react": "react-scripts start",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./src/index.css --watch",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./src/index.css --minify",
    "build": "npm run build:css && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "concurrently": "^10.0.3",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.2"
  }
}
